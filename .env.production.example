# =============================================================================
# ScamGuard Production Environment Configuration
# =============================================================================
# Copy file này thành .env.production và điền thông tin của bạn
# Generate password hash: node -e "require('bcrypt').hash('YOUR_PASSWORD', 10, (err, hash) => console.log(hash))"
# =============================================================================

# Authentication (REQUIRED)
AUTH_COOKIE_SECRET=CHANGE_ME_32_CHARACTERS_LONG_SECRET_KEY
NEXTAUTH_SECRET=CHANGE_ME_ANOTHER_SECRET_KEY
NEXTAUTH_URL=https://your-domain.com

# Admin credentials (REQUIRED)
ADMIN_EMAIL=admin@yourdomain.com

# Generate bcrypt hash: node -e "require('bcrypt').hash('your-password', 10, (err, hash) => console.log(hash))"
ADMIN_PASSWORD_HASH=CHANGE_ME_BCRYPT_HASH
ADMIN_ROLE=super_admin

# Database (REQUIRED)
DB_HOST=localhost
DB_USER=scamguard
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=scamguard

# Redis (OPTIONAL - for production rate limiting)
# Get your Redis credentials from https://upstash.com/
# REDIS_URL=redis://username:password@host:port
# REDIS_TOKEN=your-upstash-access-token

# Optional: Allowed origins for CORS (comma-separated in production)
# ALLOWED_ORIGINS=https://your-domain.com
