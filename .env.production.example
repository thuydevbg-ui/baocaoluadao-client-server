# =============================================================================
# ScamGuard Production Environment Configuration
# =============================================================================
# Copy file này thành .env.production và điền thông tin của bạn
# Generate password hash: node -e "require('bcrypt').hash('YOUR_PASSWORD', 10, (err, hash) => console.log(hash))"
# =============================================================================

# =============================================================================
# CLOUDflare Workers API (REQUIRED for production)
# =============================================================================
# API URL - Point to Cloudflare Workers API
NEXT_PUBLIC_API_URL=https://api.baocaoluadao.com
NEXT_PUBLIC_SITE_URL=https://baocaoluadao.com

# Authentication (REQUIRED)
AUTH_COOKIE_SECRET=CHANGE_ME_32_CHARACTERS_LONG_SECRET_KEY
NEXTAUTH_SECRET=CHANGE_ME_ANOTHER_SECRET_KEY
NEXTAUTH_URL=https://your-domain.com

# Admin credentials (REQUIRED)
ADMIN_EMAIL=admin@yourdomain.com

# Generate bcrypt hash: node -e "require('bcrypt').hash('your-password', 10, (err, hash) => console.log(hash))"
ADMIN_PASSWORD_HASH=CHANGE_ME_BCRYPT_HASH
ADMIN_ROLE=super_admin

# Database (REQUIRED)
DB_HOST=localhost
DB_USER=scamguard
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=scamguard

# Cloudflare D1 reads (OPTIONAL - enable to read from D1 instead of MySQL)
USE_D1_READS=true
# Prefer explicit IDs, or let app read from workers/wrangler.toml
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# Internal sync trigger (OPTIONAL - for cron automation)
INTERNAL_SYNC_TOKEN=CHANGE_ME_SYNC_TOKEN
INTERNAL_SYNC_URL=http://localhost:3001/api/internal/sync-tinnhiem

# Redis (REQUIRED for production - enables caching and rate limiting)
# Get your Redis credentials from https://upstash.com/ or other Redis providers
# REDIS_URL=redis://username:password@host:port
# Example for Upstash: REDIS_URL=redis://default:your-password@your-host.upstash.io:6379

# Google Web Risk (RECOMMENDED for /api/scan)
# Enable API: https://cloud.google.com/web-risk/docs/overview
# WEB_RISK_API_KEY=your-google-web-risk-api-key

# Optional: Allowed origins for CORS (comma-separated in production)
# ALLOWED_ORIGINS=https://your-domain.com
