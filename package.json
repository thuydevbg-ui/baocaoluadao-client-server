{
  "name": "scam-guard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "npm run sanitize:temp",
    "dev": "next dev",
    "prebuild": "npm run sanitize:temp",
    "build": "next build",
    "prestart": "npm run sanitize:temp",
    "start": "next start",
    "lint": "next lint",
    "sanitize:temp": "node scripts/relocate-temp-files.js",
    "clean:temp": "node -e \"const fs=require('fs'); const path=require('path'); const root=process.cwd(); const rm=(dir)=>{ if(!fs.existsSync(dir)) return; for(const f of fs.readdirSync(dir)){ if(/^tm_.*\\.html$/i.test(f)){ try{ fs.unlinkSync(path.join(dir,f)); }catch{} } } }; rm(root); rm(path.join(root,'.cache','tinnhiem'));\"",
    "team:auto-push": "node scripts/team-auto-push.js",
    "team:auto-push:once": "AUTO_PUSH_ONCE=1 node scripts/team-auto-push.js"
  },
  "dependencies": {
    "@flaticon/flaticon-uicons": "^3.3.1",
    "@scalar/api-reference": "^1.44.26",
    "@sentry/nextjs": "^10.40.0",
    "bcrypt": "^5.1.1",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.3",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.323.0",
    "mysql2": "^3.17.4",
    "next": "^15.1.0",
    "next-auth": "^4.24.13",
    "pino": "^10.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "redoc": "^2.5.2",
    "swagger-ui-react": "^5.31.2",
    "tailwind-merge": "^2.2.1",
    "yaml": "^1.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "20.19.33",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.2.18",
    "@types/swagger-ui-react": "^5.18.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.12",
    "playwright": "^1.58.2",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "5.9.3"
  }
}
