# ScamGuard Environment Configuration  
  
##############
# Authentication (REQUIRED)
##############
# Server-side base URLs that NextAuth uses for redirects (production + staging)
NEXTAUTH_URL=https://baocaoluadao.com
# Public site URL exposed to clients (used by client-side redirects)
NEXT_PUBLIC_SITE_URL=https://baocaoluadao.com
# Session secrets
NEXTAUTH_SECRET=your-nextauth-secret
AUTH_COOKIE_SECRET=your-32-char-secret-here
ADMIN_EMAIL=admin@scamguard.vn  

# SECURITY: Use ADMIN_PASSWORD_HASH (bcrypt) instead of plain text password!
# Generate bcrypt hash: node -e "require('bcrypt').hash('your-password', 10, (err, hash) => console.log(hash))"
ADMIN_PASSWORD_HASH=$2b$10$...your-bcrypt-hash-here...

# Legacy: Plain text password (DEPRECATED - use ADMIN_PASSWORD_HASH instead)
# ADMIN_PASSWORD=your-secure-admin-password  

ADMIN_ROLE=admin  # Options: super_admin, admin, moderator  

# Social login (Google OAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
# Twitter OAuth (v2)
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Database (REQUIRED for production)  
DB_HOST=localhost  
DB_USER=your_db_user  
DB_PASSWORD=your_db_password  
DB_NAME=scamguard  
# Internal DB manager key (used by admin sync services)
DB_MANAGER_KEY=your-db-manager-secret

# Cloudflare D1 reads (OPTIONAL)
# USE_D1_READS=true
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_D1_DATABASE_ID=
# CLOUDFLARE_API_TOKEN=

# Internal sync trigger (OPTIONAL)
# INTERNAL_SYNC_TOKEN=change-me
# INTERNAL_SYNC_URL=http://localhost:3001/api/internal/sync-tinnhiem

# Redis (OPTIONAL - for production rate limiting)
# Get your Redis credentials from https://upstash.com/
# REDIS_URL=redis://username:password@host:port
# REDIS_TOKEN=your-upstash-access-token

# Google Web Risk (RECOMMENDED for /api/scan)
# Enable API: https://cloud.google.com/web-risk/docs/overview
# WEB_RISK_API_KEY=your-google-web-risk-api-key

# Performance / Static-data mode (OPTIONAL)
# STATIC_DATA_MODE=1                # When enabled: do not auto-sync on user traffic, skip external WebRisk calls
# TINNHIEM_DISABLE_AUTO_SYNC=1      # Disable background auto sync (use /api/internal/sync-tinnhiem instead)
# CATEGORIES_CACHE_TTL_SECONDS=3600
# CATEGORIES_SEARCH_CACHE_TTL_SECONDS=120
# POLICY_VIOLATION_LOOKUP_CACHE_TTL_SECONDS=86400
# SCAN_CACHE_TTL_SECONDS=3600
# SCAN_CACHE_ERROR_TTL_SECONDS=60
# LOOKUP_CACHE_TTL_SECONDS=120
# PUBLIC_SETTINGS_CACHE_TTL_SECONDS=300

# Optional: Public demo credentials (for development only)  
# NEXT_PUBLIC_ADMIN_EMAIL=demo@scamguard.vn  
# NEXT_PUBLIC_ADMIN_PASSWORD=demo123  

# Optional: Allowed origins for CORS (comma-separated in production)  
# ALLOWED_ORIGINS=
