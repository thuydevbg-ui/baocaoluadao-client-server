# ScamGuard Environment Configuration  
  
# Authentication (REQUIRED)  
AUTH_COOKIE_SECRET=your-32-char-secret-here  
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@scamguard.vn  

# SECURITY: Use ADMIN_PASSWORD_HASH (bcrypt) instead of plain text password!
# Generate bcrypt hash: node -e "require('bcrypt').hash('your-password', 10, (err, hash) => console.log(hash))"
ADMIN_PASSWORD_HASH=$2b$10$...your-bcrypt-hash-here...

# Legacy: Plain text password (DEPRECATED - use ADMIN_PASSWORD_HASH instead)
# ADMIN_PASSWORD=your-secure-admin-password  

ADMIN_ROLE=admin  # Options: super_admin, admin, moderator  

# Social login (Google OAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database (REQUIRED for production)  
DB_HOST=localhost  
DB_USER=your_db_user  
DB_PASSWORD=your_db_password  
DB_NAME=scamguard  

# Redis (OPTIONAL - for production rate limiting)
# Get your Redis credentials from https://upstash.com/
# REDIS_URL=redis://username:password@host:port
# REDIS_TOKEN=your-upstash-access-token

# Google Web Risk (RECOMMENDED for /api/scan)
# Enable API: https://cloud.google.com/web-risk/docs/overview
# WEB_RISK_API_KEY=your-google-web-risk-api-key

# Optional: Public demo credentials (for development only)  
# NEXT_PUBLIC_ADMIN_EMAIL=demo@scamguard.vn  
# NEXT_PUBLIC_ADMIN_PASSWORD=demo123  

# Optional: Allowed origins for CORS (comma-separated in production)  
# ALLOWED_ORIGINS=
